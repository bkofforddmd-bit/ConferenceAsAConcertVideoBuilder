# Copy this file to .env (for local `netlify dev`) and set these in the
# Netlify dashboard under Site settings > Environment variables for production.
#
# These keys are used ONLY inside Netlify Functions (server-side).
# They are never sent to the browser.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
